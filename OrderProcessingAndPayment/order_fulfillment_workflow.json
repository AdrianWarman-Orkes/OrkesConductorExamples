            "loopOver": [],
            "onStateChange": {},
            "permissive": false
          }
        ],
        [
          {
            "name": "publish_order_event",
            "taskReferenceName": "publish_order_event_ref",
            "description": "Publishes an ORDER_FULFILLED event to an internal message bus for downstream systems (analytics, loyalty, CRM).",
            "inputParameters": {
              "event_type": "ORDER_FULFILLED",
              "order_id": "${workflow.input.order_id}",
              "customer_id": "${workflow.input.customer_id}",
              "order_total": "${workflow.input.order_total}",
              "tracking_number": "${create_shipment_ref.output.tracking_number}",
