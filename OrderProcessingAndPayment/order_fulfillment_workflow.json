  ],
  "outputParameters": {
    "order_id": "${workflow.input.order_id}",
    "final_status": "${notify_customer_task_ref.output.status}",
    "tracking_number": "${create_shipment_ref.output.tracking_number}",
    "payment_transaction_id": "${charge_payment_ref.output.transaction_id}"
  },
  "failureWorkflow": "order_fulfillment_failure_workflow",
