            "taskReferenceName": "reserve_inventory_ref",
            "description": "Reserves stock for each item in the order. Returns reservation_id per item.",
            "inputParameters": {
              "order_id": "${workflow.input.order_id}",
              "cart_items": "${workflow.input.cart_items}"
            },
            "type": "SIMPLE",
            "decisionCases": {},
            "defaultCase": [],
            "forkTasks": [],
            "startDelay": 0,
            "joinOn": [],
            "optional": false,
            "defaultExclusiveJoinTask": [],
            "asyncComplete": false,
            "loopOver": [],
            "retryCount": 2,
            "onStateChange": {},
            "permissive": false
          }
        ],
        [
          {
            "name": "generate_invoice",
            "taskReferenceName": "generate_invoice_ref",
            "description": "Generates a PDF invoice for the order and returns an invoice_url.",
            "inputParameters": {
              "order_id": "${workflow.input.order_id}",
              "customer_id": "${workflow.input.customer_id}",
              "cart_items": "${workflow.input.cart_items}",
              "order_total": "${workflow.input.order_total}",
              "transaction_id": "${charge_payment_ref.output.transaction_id}"
            },
            "type": "SIMPLE",
            "decisionCases": {},
            "defaultCase": [],
            "forkTasks": [],
            "startDelay": 0,
            "joinOn": [],
            "optional": false,
            "defaultExclusiveJoinTask": [],
            "asyncComplete": false,
            "loopOver": [],
            "onStateChange": {},
            "permissive": false
          }
        ],
        [
          {
            "name": "notify_warehouse",
            "taskReferenceName": "notify_warehouse_ref",
            "description": "Sends a pick-and-pack request to the warehouse management system.",
            "inputParameters": {
              "order_id": "${workflow.input.order_id}",
              "cart_items": "${workflow.input.cart_items}",
              "shipping_address": "${workflow.input.shipping_address}"
            },
            "type": "SIMPLE",
            "decisionCases": {},
            "defaultCase": [],
            "forkTasks": [],
            "startDelay": 0,
            "joinOn": [],
            "optional": false,
            "defaultExclusiveJoinTask": [],
            "asyncComplete": false,
            "loopOver": [],
            "onStateChange": {},
            "permissive": false
          }
        ]
      ],
      "startDelay": 0,
      "joinOn": [],
      "optional": false,
      "defaultExclusiveJoinTask": [],
      "asyncComplete": false,
      "loopOver": [],
      "onStateChange": {},
      "permissive": false
    },
    {
      "name": "fulfillment_join",
      "taskReferenceName": "fulfillment_join_ref",
      "description": "Waits for all three parallel fulfillment tasks to complete before continuing.",
      "inputParameters": {},
      "type": "JOIN",
      "decisionCases": {},
      "defaultCase": [],
      "forkTasks": [],
      "startDelay": 0,
      "joinOn": [
        "reserve_inventory_ref",
        "generate_invoice_ref",
        "notify_warehouse_ref"
      ],
      "optional": false,
      "defaultExclusiveJoinTask": [],
      "asyncComplete": false,
      "loopOver": [],
      "onStateChange": {},
      "permissive": false
    },
    {
      "name": "create_shipment",
      "taskReferenceName": "create_shipment_ref",
      "description": "Creates a shipping label and tracking number via the carrier API. Returns tracking_number and estimated_delivery.",
      "inputParameters": {
        "order_id": "${workflow.input.order_id}",
        "shipping_address": "${workflow.input.shipping_address}",
        "cart_items": "${workflow.input.cart_items}",
