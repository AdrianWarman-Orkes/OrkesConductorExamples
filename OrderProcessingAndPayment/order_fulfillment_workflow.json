      "defaultExclusiveJoinTask": [],
      "asyncComplete": false,
      "loopOver": [],
      "retryCount": 3,
      "onStateChange": {},
      "permissive": false
    },
    {
      "name": "post_fulfillment_fork",
      "taskReferenceName": "post_fulfillment_fork_ref",
      "description": "Runs customer notification and internal analytics event IN PARALLEL after shipment is created.",
      "inputParameters": {},
      "type": "FORK_JOIN",
      "decisionCases": {},
      "defaultCase": [],
      "forkTasks": [
        [
          {
            "name": "notify_customer",
            "taskReferenceName": "notify_customer_task_ref",
            "description": "Sends order confirmation + tracking info to the customer via email and SMS.",
            "inputParameters": {
