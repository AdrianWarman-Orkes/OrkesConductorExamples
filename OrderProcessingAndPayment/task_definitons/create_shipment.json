    "inputKeys": ["order_id", "shipping_address", "cart_items", "warehouse_confirmation"],
    "outputKeys": ["tracking_number", "carrier", "estimated_delivery", "label_url"],
    "inputTemplate": {},
    "backoffScaleFactor": 2,
    "concurrentExecLimit": 0
  }
